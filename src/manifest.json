{
  "manifest_version": 3,
  "name": "POE Ninja 繁體中文化",
  "version": "0.9.26",
  "description": "Translate poe.ninja to Traditional Chinese. Covers items, skills, passives, currency and tooltips. (POE1 + POE2)",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://poe.ninja/*",
    "https://poedb.tw/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://poe.ninja/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "POE Ninja 繁體中文化",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/translation.json", "data/translation-poe2.json"],
      "matches": ["https://poe.ninja/*"]
    }
  ]
}
